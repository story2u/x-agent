# --- Model auth (default: ChatGPT/Codex OAuth, no API key) ---
PI_PROVIDER=openai-codex
PI_MODEL=gpt-5.5-codex
# Max output tokens per turn (raise for long threads; reasoning shares this budget).
# PI_MAX_TOKENS=8192
# Codex OAuth credentials from `npm run chatgpt:oauth` — paste the printed line
# verbatim. Must be a SINGLE line (a multi-line value is truncated to "{").
# OPENAI_CODEX_OAUTH_CREDENTIALS={"openai-codex":{"type":"oauth","access":"...","refresh":"...","expires":0}}
OPENAI_CODEX_OAUTH_CREDENTIALS=
# OPENAI_CODEX_ACCESS_TOKEN=     # alternative: a raw Codex access token
# OPENAI_CODEX_BASE_URL=https://chatgpt.com/backend-api

# --- Optional fallback: plain OpenAI API key (unset PI_PROVIDER to use this path) ---
# OPENAI_API_KEY=
# OPENAI_BASE_URL=https://api.openai.com/v1

# --- Optional provider: DeepSeek OpenAI-compatible Chat Completions ---
# PI_PROVIDER=deepseek
# PI_MODEL=deepseek-v4-pro
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
# DEEPSEEK_REASONING=true

# --- Local TUI defaults (optional) ---
# X_AGENT_SKILLS_DIR=./skills      # override the local skills directory
# X_AGENT_AUDIENCE=
# X_AGENT_GOAL=
# X_AGENT_CONSTRAINTS=
